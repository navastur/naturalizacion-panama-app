<style id='altacaptcha-branding-inline-css' type='text/css'>

        .altcha-logo{
            display:inline-flex;
            align-items:center;
            justify-content:center;
            width:24px;
            height:24px;
            flex:0 0 24px;
            line-height:1;
            overflow:hidden;
        }
        .altcha-logo > *{
            display:none !important;
        }
        .altcha-logo::before{
            content:'';
            display:block;
            width:24px;
            height:24px;
            background-image:url('https://printium-pty.com/wp-content/plugins/pnmtchaltacaptcha/assets/img/panamatech-favicon.svg');
            background-size:contain;
            background-repeat:no-repeat;
            background-position:center;
        }
        .altacaptcha-field{
            margin-bottom:16px;
        }
    

.gform_wrapper .altacaptcha-field input[type=checkbox],
.gform_wrapper .altacaptcha-field input[type=checkbox]:checked {
    display: inline-block !important;
    appearance: checkbox !important;
    -webkit-appearance: checkbox !important;
    width: auto !important;
    height: auto !important;
    opacity: 1 !important;
    visibility: visible !important;
    position: relative !important;
    clip: auto !important;
    clip-path: none !important;
    margin: 0 8px 0 0 !important;
    pointer-events: auto !important;
}

/*# sourceURL=altacaptcha-branding-inline-css */
</style>
